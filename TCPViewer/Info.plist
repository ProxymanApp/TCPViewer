<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Rewritten in a derived Info.plist by scripts/update-smjobbless-requirements.sh before signing. -->
	<key>SMPrivilegedExecutables</key>
	<dict>
		<key>com.proxyman.tcpviewer.helpertool</key>
		<string>identifier "com.proxyman.tcpviewer.helpertool" and anchor apple generic and certificate leaf[subject.OU] = "$(DEVELOPMENT_TEAM)"</string>
	</dict>
	<key>SUFeedURL</key>
	<string>$(TCPVIEWER_APPCAST_URL)</string>
	<key>SUPublicEDKey</key>
	<string>$(TCPVIEWER_SPARKLE_PUBLIC_ED_KEY)</string>
	<key>TCPViewerBuildKey</key>
	<string>$(TCPVIEWER_BUILD_KEY)</string>
	<key>TCPViewerSentryDSN</key>
	<string>$(TCPVIEWER_SENTRY_DSN)</string>
	<!-- Allow only local/debug license API endpoints to use HTTP; production stays HTTPS. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSExceptionDomains</key>
		<dict>
			<key>localhost</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
			<key>proxyman.debug</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
		</dict>
	</dict>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleTypeName</key>
			<string>Packet Capture</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.tcpdump.pcap</string>
				<string>org.tcpdump.pcapng</string>
			</array>
			<key>NSDocumentClass</key>
			<string>$(PRODUCT_MODULE_NAME).Document</string>
		</dict>
	</array>
	<key>UTImportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeDescription</key>
			<string>Packet Capture</string>
			<key>UTTypeIdentifier</key>
			<string>com.tcpdump.pcap</string>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>pcap</string>
				</array>
			</dict>
		</dict>
		<dict>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeDescription</key>
			<string>Packet Capture Next Generation</string>
			<key>UTTypeIdentifier</key>
			<string>org.tcpdump.pcapng</string>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>pcapng</string>
				</array>
			</dict>
		</dict>
	</array>
</dict>
</plist>
